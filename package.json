{
  "name": "fluxevengine",
  "private": true,
  "packageManager": "bun@1.3.9",
  "scripts": {
    "dev": "bun run --cwd frontend dev",
    "start": "bun run --cwd frontend start",
    "build": "bun run --cwd frontend build",
    "lint": "bun run --cwd frontend lint",
    "lint:fix": "bun run --cwd frontend lint:fix",
    "lint:type": "bun run --cwd frontend lint:type",
    "check": "bun run --cwd frontend check",
    "api": "bun run uvicorn dev",
    "uvicorn": "powershell -ExecutionPolicy Bypass -File ./scripts/uvicorn.ps1"
  }
}
