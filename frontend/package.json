{
  "name": "fluxev-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.9",
  "scripts": {
    "dev": "bun --bun next dev --port 8000",
    "build": "bun --bun next build",
    "start": "bun --bun next start --port 8000",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "lint:type": "tsc --noEmit",
    "check": "bun run lint && bun run lint:type",
    "fix": "bun run lint:fix"
  },
  "dependencies": {
    "@internationalized/date": "^3.12.1",
    "@teach-in/react": "^1.6.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "plotly.js-dist-min": "^3.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "16.2.1",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^25.3.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^9.29.0",
    "eslint-config-next": "16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
